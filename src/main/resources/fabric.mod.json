{
	"schemaVersion": 1,
	"id": "reinvigorated",
	"version": "${version}",
	"name": "Reinvigorated",
	"description": "Lightweight mod aimed at reinvigorating Minecraft survival building.",
	"authors": [
		"CodedStingray"
	],
	"contact": {
		"homepage": "https://codedstingray.net/",
		"sources": "https://github.com/CodedStingray/Reinvigorated"
	},
	"license": "CC0-1.0",
	"icon": "assets/reinvigorated/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.codedstingray.Reinvigorated"
		],
		"client": [
			"net.codedstingray.client.ReinvigoratedClient"
		]
	},
	"mixins": [
		"reinvigorated.mixins.json",
		{
			"config": "reinvigorated.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}